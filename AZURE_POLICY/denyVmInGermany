{
  "mode": "All",
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.Compute/virtualMachines"
        },
        {
          "field": "location",
          "in": [
            "germanywestcentral",
            "germanynorth"
          ]
        }
      ]
    },
    "then": {
      "effect": "deny"
    }
  }
}
